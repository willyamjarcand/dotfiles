[include]
  path = ~/.gitconfig-default
[include]
  path = ~/.config/wealthsimple/gitconfig
[includeIf "gitdir:~/dotfiles/**"]
  path = ~/.gitconfig-personal
[init]
  defaultBranch = main
[push]
  default = current
[color]
  ui = auto
[core]
  excludesfile = ~/.gitignore
  editor = nvim
  autocrlf = input
[merge]
  ff = only
  tool = nvimdiff
[commit]
  template = ~/.gitmessage
[fetch]
  prune = true
[rebase]
  autosquash = true
[diff]
  colorMoved = zebra
[user]
  name = Willyam Arcand
[alias]
  st = status
  ci = commit
  br = branch
  co = checkout
  g = git
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
